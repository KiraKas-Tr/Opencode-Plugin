{
  "$schema": "https://raw.githubusercontent.com/Opencode-DCP/opencode-dynamic-context-pruning/master/dcp.schema.json",

  /* ── DCP Beta: compress-only model ──────────────────────────────────────
   * Single `compress` tool replaces the old 3-tool system (distill/compress/prune).
   * Do NOT add top-level `prune` or `distill` blocks — unsupported in beta.
   * Config location (read-only by DCP): ~/.cache/opencode/node_modules/
   * ───────────────────────────────────────────────────────────────────── */

  "enabled": true,
  "pruneNotification": "minimal",

  /* ── Nudge configuration ──────────────────────────────────────────────── */
  "nudgeFrequency": 5,
  "iterationNudgeThreshold": 15,
  "nudgeForce": "soft",

  /* ── Compress ─────────────────────────────────────────────────────────── */
  "compress": {
    "permission": "ask",
    "maxContextLimit": 150000,
    "minContextLimit": 50000
  },

  /* ── Strategies ───────────────────────────────────────────────────────── */
  "strategies": {
    "deduplication": { "enabled": true },
    "supersedeWrites": { "enabled": true },
    "purgeErrors": { "enabled": true, "turns": 4 }
  },

  /* ── Auto-protected tools (DCP will never prune their output) ─────────── */
  "protectedToolNames": [
    "task",
    "skill",
    "todowrite",
    "todoread",
    "compress",
    "batch",
    "plan_enter",
    "plan_exit"
  ]
}
