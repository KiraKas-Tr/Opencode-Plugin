{
  "mcpServers": {
    "chrome-devtools": {
      "type": "local",
      "command": ["npx", "-y", "@modelcontextprotocol/server-puppeteer"],
      "description": "Chrome DevTools — network, console, DOM, performance via Puppeteer",
      "tools": [
